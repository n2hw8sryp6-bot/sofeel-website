<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>So Feel | Premium Paper & Ceramic Products</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-b from-[#FDFAF5] to-white">
    <!-- Navigation -->
    <header class="fixed w-full top-0 z-50 bg-white/95 backdrop-blur-md border-b border-[#E8DDD2]">
        <nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="text-2xl font-bold">so<span class="text-[#C17A6B]">feel</span></div>
            <ul class="hidden md:flex gap-8">
                <li><a href="#products" class="text-gray-600 hover:text-[#8B6F47]">Products</a></li>
                <li><a href="#features" class="text-gray-600 hover:text-[#8B6F47]">Why Us</a></li>
                <li><a href="#contact" class="bg-gradient-to-r from-[#C17A6B] to-[#8B6F47] text-white px-6 py-2 rounded-full">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero -->
    <section class="pt-32 pb-20 px-6 text-center">
        <h1 class="text-6xl font-bold mb-6 bg-gradient-to-r from-[#8B6F47] to-[#4A5D3A] bg-clip-text text-transparent">Well-Being & Comfort</h1>
        <p class="text-xl text-gray-600 mb-8">Premium paper and ceramic products designed for everyday elegance</p>
        <button class="bg-gradient-to-r from-[#C17A6B] to-[#8B6F47] text-white px-8 py-3 rounded-full font-semibold">Explore Products</button>
    </section>

    <!-- Products -->
    <section id="products" class="max-w-6xl mx-auto px-6 py-20">
        <h2 class="text-5xl font-bold text-center mb-16">Our Collections</h2>
        <div class="grid md:grid-cols-4 gap-6">
            <div class="bg-white rounded-xl p-6 shadow-md">
                <div class="text-5xl mb-4">📄</div>
                <h3 class="text-xl font-bold text-[#8B6F47] mb-2">Premium Paper</h3>
                <p class="text-gray-600 text-sm">Eco-friendly, high-quality paper goods</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-md">
                <div class="text-5xl mb-4">🫖</div>
                <h3 class="text-xl font-bold text-[#8B6F47] mb-2">Ceramic Ware</h3>
                <p class="text-gray-600 text-sm">Handcrafted ceramic tableware</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-md">
                <div class="text-5xl mb-4">🏠</div>
                <h3 class="text-xl font-bold text-[#8B6F47] mb-2">Home Items</h3>
                <p class="text-gray-600 text-sm">Daily-use essentials with style</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-md">
                <div class="text-5xl mb-4">✨</div>
                <h3 class="text-xl font-bold text-[#8B6F47] mb-2">Premium Lines</h3>
                <p class="text-gray-600 text-sm">Limited edition curated pieces</p>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section id="features" class="bg-gradient-to-r from-[#4A5D3A] to-[#3a4a2a] text-white py-20 px-6 my-12">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-4xl font-bold text-center mb-16">Why Choose So Feel</h2>
            <div class="grid md:grid-cols-3 gap-12 text-center">
                <div>
                    <div class="text-5xl mb-4">🌿</div>
                    <h3 class="text-2xl font-bold mb-2">Sustainable</h3>
                    <p>Committed to environmental responsibility</p>
                </div>
                <div>
                    <div class="text-5xl mb-4">💎</div>
                    <h3 class="text-2xl font-bold mb-2">Premium Quality</h3>
                    <p>Materials that last and bring joy</p>
                </div>
                <div>
                    <div class="text-5xl mb-4">🤝</div>
                    <h3 class="text-2xl font-bold mb-2">Customer Care</h3>
                    <p>Dedicated support, guaranteed satisfaction</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="bg-[#F5EFE7] py-20 px-6">
        <div class="max-w-2xl mx-auto text-center">
            <h2 class="text-4xl font-bold text-[#8B6F47] mb-4">Get in Touch</h2>
            <div class="grid md:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-lg border border-[#E8DDD2]">
                    <strong class="text-[#8B6F47]">Email</strong>
                    <p class="text-gray-600">hello@sofeel.com</p>
                </div>
                <div class="bg-white p-6 rounded-lg border border-[#E8DDD2]">
                    <strong class="text-[#8B6F47]">Phone</strong>
                    <p class="text-gray-600">+1 (800) 123-4567</p>
                </div>
                <div class="bg-white p-6 rounded-lg border border-[#E8DDD2]">
                    <strong class="text-[#8B6F47]">Location</strong>
                    <p class="text-gray-600">New Delhi, India</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white text-center py-8">
        <p>&copy; 2024 So Feel. All rights reserved.</p>
    </footer>
</body>
</html>
